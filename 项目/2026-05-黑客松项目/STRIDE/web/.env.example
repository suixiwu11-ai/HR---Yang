# 复制为 .env.local（勿提交 GitHub）

# ========== Turso 云端 SQLite（Netlify 持久化，可选）==========
# 两个都填则走 Turso；都不填则本地 data/stride.db
# TURSO_DATABASE_URL=libsql://your-db-name-xxx.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ========== DeepSeek（推荐，OpenAI 兼容）==========
LLM_PROVIDER=deepseek
LLM_API_KEY=你的_DeepSeek_API_Key
# 与官方文档一致：https://api.deepseek.com（代码会再拼 /chat/completions）
LLM_BASE_URL=https://api.deepseek.com
# 勿加引号、勿尾部斜杠；若写成 .../v1 也会自动纠正
LLM_MODEL=deepseek-chat
# 可选推理模型：deepseek-reasoner
# LLM_MODEL=deepseek-reasoner
# 可选：出站超时毫秒，默认 55000
# LLM_FETCH_TIMEOUT_MS=55000

# Key 在 https://platform.deepseek.com/api_keys 创建

# ========== 通义千问 Qwen（可选，阿里云百炼 / DashScope）==========
# LLM_PROVIDER=qwen
# LLM_API_KEY=你的_DashScope_API_Key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_MODEL=qwen3.5-plus
# 国际站 / Netlify 海外节点：
# LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
