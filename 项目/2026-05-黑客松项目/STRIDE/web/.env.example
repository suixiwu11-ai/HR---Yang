# 复制为 .env.local（勿提交 GitHub）

# ========== Turso 云端 SQLite（Netlify 持久化，可选）==========
# 两个都填则走 Turso；都不填则本地 data/stride.db
# TURSO_DATABASE_URL=libsql://your-db-name-xxx.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ========== 通义千问 Qwen3.5（推荐，阿里云百炼 / DashScope）==========
LLM_PROVIDER=qwen
LLM_API_KEY=你的_DashScope_API_Key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 勿加引号、勿尾部斜杠；Netlify 海外部署优先用国际站 BASE_URL（见下方）
# 未设置时默认 qwen-plus；已开通 3.5 可改为 qwen3.5-plus
LLM_MODEL=qwen-plus
# LLM_MODEL=qwen3.5-plus
# 更快更省：qwen-turbo / qwen3.5-flash（以控制台为准）
# 可选：出站超时毫秒，默认 55000
# LLM_FETCH_TIMEOUT_MS=55000

# 国际站 / Netlify 海外节点推荐：
# LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ========== 其他厂商（OpenAI 兼容）==========
# LLM_PROVIDER=deepseek
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
