# STRIDE Web — Netlify 环境变量导入模板（可提交 Git）
# 用法：复制为 env.netlify，填入真实 LLM_API_KEY 后导入；或直接在 Netlify UI 逐项添加
# Netlify → Site configuration → Environment variables → Import from .env
# 导入后务必 Clear cache and deploy site（重新部署）才生效
# 警告：勿将含真实 API Key 的 env.netlify 提交到仓库

# 厂商标识（qwen / deepseek 等，见 src/lib/llm.ts）
LLM_PROVIDER=qwen

# 百炼 DashScope API Key（导入前替换占位符，或导入后在 UI 编辑）
LLM_API_KEY=your-dashscope-api-key-here

# OpenAI 兼容接口（勿加引号、勿尾部斜杠）
# Netlify 海外节点优先用国际站，避免 fetch failed：
# LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认 qwen-plus；已开通 3.5 可改为 qwen3.5-plus
LLM_MODEL=qwen-plus

# 其他厂商示例（取消注释并改 LLM_PROVIDER）：
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your-deepseek-api-key-here
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# llm.ts 也支持 DASHSCOPE_API_KEY / OPENAI_API_KEY 作为 Key 别名，一般无需单独配置
# Node 版本在 netlify.toml 中已设为 20，无需在此导入

# ========== Turso 云端数据库（Netlify 持久化，推荐生产）==========
# 详见 DEPLOY-TURSO.md；勿提交真实 token
TURSO_DATABASE_URL=libsql://your-db-name-xxx.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here
